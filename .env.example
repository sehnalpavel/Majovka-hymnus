# ============== GEMINI ==============
# Tvůj klíč z https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza_...vlož_svůj_klíč_sem

# ============== CLOUDFLARE R2 ==============
# 1) Vytvoř bucket na https://dash.cloudflare.com → R2
# 2) V "Manage R2 API tokens" vytvoř token s "Object Read & Write" pro tenhle bucket
# 3) Bucket → Settings → Public access → povol "r2.dev subdomain" (nebo nastav custom doménu)
R2_ACCOUNT_ID=tvoje_account_id
R2_ACCESS_KEY_ID=tvoj_access_key
R2_SECRET_ACCESS_KEY=tvoj_secret
R2_BUCKET=majova-regata-hymny
# Veřejná URL bucketu (z R2 dashboardu, např. https://pub-abc123.r2.dev)
R2_PUBLIC_URL=https://pub-xxxxxxxxxx.r2.dev

# ============== SERVER ==============
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# Cesta k persistent storage (pro SQLite). Lokálně nech prázdné (default ./data).
# Na Railway nastav na cestu, kam mountne Volume (např. /data nebo /var/data).
# DATA_DIR=/data

# Volitelné — výchozí hodnoty stačí
TEXT_MODEL=gemini-2.5-flash
MUSIC_MODEL_CLIP=lyria-3-clip-preview
MUSIC_MODEL_PRO=lyria-3-pro-preview
